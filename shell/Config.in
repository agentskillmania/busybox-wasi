menu "Shells"

# WASM 构建只使用 wsh，ash/hush 已移除
config SH_IS_NONE
	bool
	default y

config BASH_IS_NONE
	bool
	default y

# 以下隐藏选项被 libbb/appletlib.c 等代码引用，必须保留定义
config FEATURE_SH_STANDALONE
	bool
	default n

config FEATURE_SH_NOFORK
	bool
	default n

config FEATURE_SH_MATH
	bool
	default n

config SHELL_WSH
	bool # hidden option

config WSH
	bool "wsh (WASM shell)"
	default n
	select SHELL_WSH
	help
	  Minimal shell for WASM environments. Supports variable assignment,
	  command substitution, and serial pipeline execution.
	  No fork/pipe support - designed for single-process WASM runtime.


endmenu
