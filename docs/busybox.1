\&        chpasswd, chpst, chroot, cksum, cmp, comm, cp, cpio, crc32, crond,
\&        crontab, cryptpw, cttyhack, cut, date, dc, dd, delgroup, deluser,
\&        devmem, df, dhcprelay, diff, dirname, dmesg, dnsd, dos2unix, dpkg,
\&        dpkg\-deb, du, dumpleases, echo, ed, egrep, eject, env, envdir,
\&        envuidgid, expand, expr, factor, fakeidentd, fallocate, false,
\&        fatattr, fgrep, flock, fold, free, fsck.minix, fsync, ftpd, ftpget,
\&        ftpput, fuser, getopt, grep, groups, gunzip, gzip, halt, hd, head,
\&        hexdump, hexedit, hostid, hostname, httpd, id, ifdown, ifup,
\&        install, iostat, ipcalc, kill, killall, killall5, last, less, link,
\&        ln, login, logname, lpd, lpq, lpr, ls, lsof, lspci, lsscsi, lsusb,
