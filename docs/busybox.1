\&        pgrep, pidof, pipe_progress, pivot_root, pkill, pmap, popmaildir,
\&        powertop, printenv, printf, ps, pscan, pstree, pwd, pwdx, rdate,
\&        rdev, readahead, readlink, readprofile, realpath, reformime,
\&        remove\-shell, renice, resume, rev, rm, rmdir, rpm, rpm2cpio,
\&        rtcwake, run\-parts, runlevel, runsvdir, rx, scriptreplay, sed, seq,
\&        setsid, setuidgid, sh, sha1sum, sha256sum, sha3sum, sha512sum,
