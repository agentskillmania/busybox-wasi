package agentskillmania:subcommand;

/// Sub-command interface for git (libgit2 CLI).
interface git {
    /// Execute with args. Host passes its cwd; guest chdir()s before running.
    /// stdout-file/stdin-file: paths to redirect I/O (empty string = no redirect).
    /// Returns the process exit code (0 = success, non-zero = failure).
    execute: func(cwd: string, args: list<string>, stdout-file: string, stdin-file: string) -> s32;
}

/// Sub-command interface for python (MicroPython).
interface python {
    /// Execute with args. Host passes its cwd; guest chdir()s before running.
    /// stdout-file/stdin-file: paths to redirect I/O (empty string = no redirect).
    /// Returns the process exit code (0 = success, non-zero = failure).
    execute: func(cwd: string, args: list<string>, stdout-file: string, stdin-file: string) -> s32;
}

/// World for a host component that consumes sub-commands.
world host-runner {
    import git;
    import python;
}

/// World for a guest component that provides the git sub-command.
world guest-git {
    export git;
}

/// World for a guest component that provides the python sub-command.
world guest-python {
    export python;
}
